<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.cafeuniv.ppi.controller.DashboardController">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

            <!-- Logo JazzCoffee en barra superior -->
            <ImageView fitHeight="36" preserveRatio="true" smooth="true">
                <image>
                    <Image url="file:/C:/Users/esteb/Desktop/trabajos2semestre/PPI/DOCUMENTACION%20PPI/LOGO%20.jpg" />
                </image>
            </ImageView>

            <Label text="JazzCoffee - Dashboard" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Button text="Categorías" onAction="#openCategorias" />
            <Button text="Productos" onAction="#openProductos" />
            <Button text="Movimientos" onAction="#openMovimientos" />
            <Button text="POS" onAction="#openPos" />
            <Button text="Usuarios" onAction="#openUsuarios" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Cerrar sesión" onAction="#onCerrarSesion" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" alignment="TOP_LEFT">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
            <HBox spacing="24">
                <Label fx:id="ventasHoyLabel"/>
                <Label fx:id="ticketPromedioLabel"/>
                <Label fx:id="topProductoLabel"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="notificacionFichosLabel" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-padding: 4 8 4 8; -fx-background-radius: 4;" />
            </HBox>
            <LineChart fx:id="ventasChart" title="Ventas en tiempo real" legendVisible="false">
                <xAxis>
                    <CategoryAxis label="Tiempo"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Monto"/>
                </yAxis>
            </LineChart>
            <HBox spacing="8">
                <Button text="Respaldo BD" onAction="#backupDb" />
                <Button text="Restaurar BD" onAction="#restoreDb" />
            </HBox>
        </VBox>
    </center>
</BorderPane>


