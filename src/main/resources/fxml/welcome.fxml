<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.cafeuniv.ppi.controller.WelcomeController">
    <center>
        <VBox alignment="CENTER" spacing="24.0">
            <padding>
                <Insets top="48" right="48" bottom="48" left="48" />
            </padding>
            <Label text="JazzCoffee" style="-fx-font-size: 32px; -fx-font-weight: bold;" />
            <Label text="Bienvenido" style="-fx-font-size: 18px;" />
            <Separator prefWidth="300" />
            <VBox spacing="16" alignment="CENTER">
                <Button text="Cliente" onAction="#openClienteLogin" prefWidth="200" prefHeight="40" 
                        style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                <Button text="Empleado / Administrador" onAction="#openEmpleadoLogin" prefWidth="200" prefHeight="40" 
                        style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            </VBox>
        </VBox>
    </center>
</BorderPane>

